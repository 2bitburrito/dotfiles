{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "messages_page_up": "ctrl+u",
    "messages_page_down": "ctrl+d",
    "messages_half_page_up": "ctrl+y",
    "messages_half_page_down": "ctrl+e",
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "oauth": {
        "scope": "tools:read write"
      }
    }
  }
}
